{
  "name": "lambdas",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "src",
  "prefix": "lambdas",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "./mvnw clean package -DskipTests",
        "cwd": "packages/backend/lambdas"
      },
      "configurations": {
        "production": {
          "command": "./mvnw clean package -DskipTests"
        }
      },
      "cache": true,
      "outputs": ["{projectRoot}/target"]
    },
    "build:with-tests": {
      "executor": "nx:run-commands",
      "options": {
        "command": "./mvnw clean package",
        "cwd": "packages/backend/lambdas"
      },
      "cache": true,
      "outputs": ["{projectRoot}/target"]
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "./mvnw test",
        "cwd": "packages/backend/lambdas"
      }
    },
    "clean": {
      "executor": "nx:run-commands",
      "options": {
        "command": "./mvnw clean",
        "cwd": "packages/backend/lambdas"
      }
    },
    "format": {
      "executor": "nx:run-commands",
      "options": {
        "command": "./mvnw spotless:apply",
        "cwd": "packages/backend/lambdas"
      }
    }
  },
  "tags": ["type:app", "scope:backend"]
}
